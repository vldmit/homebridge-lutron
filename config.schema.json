{
    "pluginAlias": "Lutron",
    "pluginType": "platform",
    "singular": true,
    "customUi": true,
    "customUiPath": "./ui",
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "type": "string",
                "title": "Plugin Name",
                "default": "Lutron",
                "required": true
            },
            "cco": {
                "type": "boolean",
                "title": "Expose Contact Closures",
                "default": false
            },
            "dimmers": {
                "type": "boolean",
                "title": "Expose Dimmers",
                "default": false
            },
            "fans": {
                "type": "boolean",
                "title": "Expose Fans",
                "default": false
            },
            "keypads": {
                "type": "boolean",
                "title": "Expose Keypads",
                "default": true
            },
            "sensors": {
                "type": "boolean",
                "title": "Expose Sensors",
                "default": true
            },
            "remotes": {
                "type": "boolean",
                "title": "Expose Remotes",
                "default": true
            },
            "shades": {
                "type": "boolean",
                "title": "Expose Shades",
                "default": false
            },
            "strips": {
                "type": "boolean",
                "title": "Expose Light Strips",
                "default": true
            },
            "switches": {
                "type": "boolean",
                "title": "Expose Switches",
                "default": false
            },
            "timeclocks": {
                "type": "boolean",
                "title": "Expose Timeclocks",
                "default": true
            },
            "jukeaudio": {
                "type": "object",
                "title": "Jukeaudio Control",
                "description": "Hook Pico Volume Up/Down buttons to the local jukeaudio-control service for relative volume and hold-to-ramp.",
                "properties": {
                    "enabled": {
                        "type": "boolean",
                        "title": "Enable",
                        "default": true
                    },
                    "baseUrl": {
                        "type": "string",
                        "title": "Service Base URL",
                        "description": "e.g. http://127.0.0.1:9002",
                        "default": "http://127.0.0.1:9002",
                        "required": true
                    },
                    "username": {
                        "type": "string",
                        "title": "HTTP Basic Username",
                        "description": "Control service auth (not the Juke Admin password)",
                        "default": "control",
                        "required": true
                    },
                    "password": {
                        "type": "string",
                        "title": "HTTP Basic Password",
                        "required": true
                    },
                    "step": {
                        "type": "integer",
                        "title": "Press Step",
                        "description": "Volume change on initial press",
                        "default": 5,
                        "minimum": 1,
                        "maximum": 100
                    },
                    "holdDelayMs": {
                        "type": "integer",
                        "title": "Hold Delay (ms)",
                        "description": "Start ramp if still held after this many ms",
                        "default": 450,
                        "minimum": 0
                    },
                    "doubleClickMs": {
                        "type": "integer",
                        "title": "Double-Click Window (ms)",
                        "description": "After a short press, second press sets volume to 100 (up) or 0 (down)",
                        "default": 450,
                        "minimum": 0
                    },
                    "timeoutMs": {
                        "type": "integer",
                        "title": "HTTP Timeout (ms)",
                        "default": 3000,
                        "minimum": 100
                    },
                    "bindings": {
                        "type": "array",
                        "title": "Remote Bindings",
                        "description": "Map Pico remotes to jukeaudio-control zones (real or virtual)",
                        "items": {
                            "type": "object",
                            "properties": {
                                "deviceName": {
                                    "type": "string",
                                    "title": "Remote Device Name",
                                    "description": "Exact name as shown in Homebridge logs, e.g. Room Audio remote Position 1",
                                    "required": true
                                },
                                "zone": {
                                    "type": "string",
                                    "title": "Zone Name",
                                    "description": "Juke zone or virtual zone name (e.g. Kitchen Speaker, Upper Floor)",
                                    "required": true
                                },
                                "volumeUp": {
                                    "type": "string",
                                    "title": "Volume Up Button Name",
                                    "default": "Volume Up"
                                },
                                "volumeDown": {
                                    "type": "string",
                                    "title": "Volume Down Button Name",
                                    "default": "Volume Down"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
