#!/usr/bin/env node

const colors = require("colors");
const fs = require("fs");
const logger = require("js-logger");
const path = require("path");

const { build } = require("esbuild");

const log = logger.get("Build");

logger.setDefaults({ useDefaults: true });

const leapClientRoot = path.resolve(__dirname, "node_modules/@mkellsy/leap-client");
const leapClientSrc = path.resolve(leapClientRoot, "src/index.ts");
// Prefer TypeScript source when developing against a file: linked leap-client clone.
const leapClientEntry = fs.existsSync(leapClientSrc) ? leapClientSrc : undefined;

const options = {
    bundle: true,
    minify: true,
    sourcemap: (process.argv[2] || "").toLowerCase() !== "release",
    target: "es6",
    platform: "node",
    external: ["homebridge", "bson"],
    logLevel: "error",
    legalComments: "none",
    ...(leapClientEntry
        ? {
              alias: {
                  "@mkellsy/leap-client": leapClientEntry,
              },
          }
        : {}),
};

const authoritySource = path.resolve(leapClientRoot, "authority");
const authorityDest = path.resolve(__dirname, "authority");

log.info(`authority ${colors.cyan(authorityDest)}`);
if (leapClientEntry) {
    log.info(`leap-client source ${colors.cyan(leapClientEntry)}`);
}

if (!fs.existsSync(authoritySource)) {
    log.error(`missing authority at ${authoritySource}`);
    process.exit(1);
}

fs.copyFileSync(authoritySource, authorityDest);

const tasks = [
    { input: path.resolve(__dirname, "src/index.ts"), output: path.resolve(__dirname, "lib/index.js") },
    { input: path.resolve(__dirname, "src/CLI.ts"), output: path.resolve(__dirname, "lib/cli.js") },
    { input: path.resolve(__dirname, "src/Server.ts"), output: path.resolve(__dirname, "ui/server.js") },
];

const jobs = [];

fs.rmSync(path.resolve(__dirname, "lib"), { recursive: true, force: true });
fs.rmSync(path.resolve(__dirname, "ui/server.js"), { force: true });
fs.rmSync(path.resolve(__dirname, "ui/server.js.map"), { force: true });

for (let i = 0; i < tasks.length; i++) {
    const task = tasks[i];

    log.info(`esbuild ${colors.cyan(task.output)}`);

    jobs.push(build({ ...options, entryPoints: [task.input], outfile: task.output }));
}

Promise.all(jobs)
    .then(() => {
        log.info(`${colors.green("BUILD COMPLETE")}\n`);
    })
    .catch((error) => {
        log.error(error);
        log.error(`${colors.red("BUILD FAILED")}\n`);
    });
